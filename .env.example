# vLLM Studio example environment.
# Copy values into your shell or a local .env file. Do not commit real tokens.

# Frontend -> backend API base. Browser-visible.
NEXT_PUBLIC_API_BASE=http://localhost:8000
NEXT_ALLOWED_DEV_ORIGINS=localhost,127.0.0.1

# FastAPI control plane.
VLLM_STUDIO_HOST=0.0.0.0
VLLM_STUDIO_PORT=8000
VLLM_STUDIO_DATA=./data

# Managed vLLM engine endpoint.
VLLM_ENGINE_HOST=127.0.0.1
VLLM_ENGINE_PORT=8001
VLLM_ENGINE_RUNNER=process
VLLM_DOCKER_IMAGE=vllm/vllm-openai:latest

# Runtime tuning.
VLLM_STUDIO_GPU_UTIL=0.90
VLLM_STARTUP_TIMEOUT=900
HF_HOME=~/.cache/huggingface

# Optional private Hugging Face access. Leave blank in committed examples.
# HF_TOKEN=
# HUGGING_FACE_HUB_TOKEN=

# Optional TurboQuant wrapper for the process runner.
VLLM_TURBOQUANT=0
VLLM_TURBOQUANT_KEY_BITS=3
VLLM_TURBOQUANT_VALUE_BITS=2
VLLM_TURBOQUANT_BUFFER_SIZE=128
VLLM_TURBOQUANT_INITIAL_LAYERS=4
